# Provider selection: openai | azure | anthropic | google
LLM_PROVIDER=openai

# Shared token limit (applies to all providers)
MODEL_MAX_TOKENS=1500

# OpenAI (default)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=o1

# Azure OpenAI (set LLM_PROVIDER=azure to use)
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_MODEL=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Anthropic (set LLM_PROVIDER=anthropic to use)
# ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini (set LLM_PROVIDER=google to use)
# GOOGLE_API_KEY=your_google_api_key
# GOOGLE_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# MCP server transport
# ---------------------------------------------------------------------------
# HTTP transport (used by the Streamlit app)
# Start with: mcp-server-cyberthreats-http
# Then set this URL so ui.py connects over HTTP instead of spawning a subprocess
MCP_SERVER_URL=http://localhost:8000/mcp

# HTTP server bind settings (used by run_mcp_server_http)
MCP_HTTP_HOST=localhost
MCP_HTTP_PORT=8000

# stdio transport is used automatically by VSCode and Claude Code Desktop.
# No extra config needed — they launch the server as a subprocess via:
#   mcp-server-cyberthreats-mcp   (entry point in pyproject.toml)

# ---------------------------------------------------------------------------
# CISA threat feed settings
# ---------------------------------------------------------------------------
CISA_THREAT_LIMIT=8
# Timeout in seconds for the HTTP request to the CISA KEV feed
CISA_FEED_TIMEOUT=10

# Streamlit MCP context cache TTL in seconds
MCP_CACHE_TTL=900

# ---------------------------------------------------------------------------
# ClickUp integration
# ---------------------------------------------------------------------------
CLICKUP_WORKSPACE_ID=90171006201
CLICKUP_SPACE_ID=90174782063
CLICKUP_LIST_ID=901712073571

# ---------------------------------------------------------------------------
# Observability — LangSmith
# ---------------------------------------------------------------------------
# Set LANGSMITH_TRACING=true and provide an API key to enable tracing.
# run_security_audit() and mcp_fetch_context are both @traceable.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=cyberthreats
